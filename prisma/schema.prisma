// PlanIt core models, enums, and PostgreSQL relational mapping

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum SubscriptionPlan {
  TRIAL
  PREMIUM
  FREE
  CANCELED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum FocusMode {
  POMODORO
  FLOWTIME
  TIMEBOXING
  RULE_52_17
  ULTRADIAN
  CUSTOM
}

enum SessionStatus {
  COMPLETED
  INTERRUPTED
}

// Models

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  name             String?
  password         String
  
  // Gamification metrics
  xp               Int              @default(0)
  level            Int              @default(1)

  // SaaS billing and limits
  plan             SubscriptionPlan @default(TRIAL)
  trialEndsAt      DateTime?
  stripeCustomerId String?          @unique
  stripeSubId      String?          @unique

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tasks            Task[]
  habits           Habit[]
  focusSessions    FocusSession[]  
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  focusSessions FocusSession[]

  // Optimization: Speeds up queries filtering by user
  @@index([userId])
}

model Habit {
  id            String     @id @default(uuid())
  title         String
  currentStreak Int        @default(0)
  longestStreak Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  logs          HabitLog[]

  // Optimization: Speeds up queries filtering by user
  @@index([userId])
}

model HabitLog {
  id          String   @id @default(uuid())
  completedAt DateTime @default(now())
  
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  // Optimization: Accelerates consistency graph generation and streak calculations
  @@index([habitId])
}

model FocusSession {
  id        String        @id @default(uuid())
  mode      FocusMode     @default(POMODORO)
  startTime DateTime      @default(now())
  endTime   DateTime?
  duration  Int           // Stored in seconds for efficient aggregation
  status    SessionStatus @default(COMPLETED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional relation: A session might be generic (no specific task)
  taskId    String?
  task      Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taskId])
}